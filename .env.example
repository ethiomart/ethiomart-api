# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# IMPORTANT: Update DB_PASSWORD with your actual MySQL root password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-now
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-too
JWT_REFRESH_EXPIRE=7d

# Chapa Payment Gateway Configuration
# Get your keys from: https://dashboard.chapa.co
# For testing, use CHASECK_TEST prefix; for production, use CHASECK prefix
CHAPA_SECRET_KEY=CHASECK_TEST_YourTestKeyHere
CHAPA_PUBLIC_KEY=CHAPUBK_TEST_YourPublicKeyHere
CHAPA_ENCRYPTION_KEY=YourEncryptionKeyHere
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_WEBHOOK_SECRET=your_webhook_secret_change_in_production
CHAPA_TEST_MODE=true

# Chapa Callback and Return URLs
# IMPORTANT: Update these URLs for your deployment environment
# Callback URL: Where Chapa sends webhook notifications about payment status
# Return URL: Where customers are redirected after completing payment
# For production, use HTTPS URLs pointing to your domain
CHAPA_CALLBACK_URL=http://localhost:5000/api/payments/callback
CHAPA_RETURN_URL=http://localhost:5000/api/payments/return

# Payment Configuration
# Update these URLs based on your deployment environment
PAYMENT_CALLBACK_URL=http://localhost:5000/api/payments/webhook
PAYMENT_RETURN_URL=http://localhost:3000/payment/return
PAYMENT_CURRENCY=ETB
PAYMENT_TIMEOUT=30000

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@ecommerce.com

# Frontend URLs
CUSTOMER_APP_URL=http://localhost:3000
SELLER_APP_URL=http://localhost:3001
ADMIN_PANEL_URL=http://localhost:3002

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
