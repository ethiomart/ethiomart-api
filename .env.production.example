# Production Environment Configuration
# IMPORTANT: Copy this file to .env.production and update with actual production values
# NEVER commit .env.production to version control

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# CRITICAL: Use production database credentials
DB_HOST=your-production-db-host.com
DB_PORT=3306
DB_NAME=ecommerce_production
DB_USER=ecommerce_prod_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_NOW

# JWT Configuration
# CRITICAL: Generate strong random secrets for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_STRONG_SECRET_64_CHARS_MINIMUM
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_STRONG_SECRET_64_CHARS
JWT_REFRESH_EXPIRE=7d

# Chapa Payment Gateway Configuration - PRODUCTION
# Get your PRODUCTION keys from: https://dashboard.chapa.co
# CRITICAL: Use PRODUCTION keys (CHASECK prefix, NOT CHASECK_TEST)
CHAPA_SECRET_KEY=CHASECK_YOUR_PRODUCTION_SECRET_KEY
CHAPA_PUBLIC_KEY=CHAPUBK_YOUR_PRODUCTION_PUBLIC_KEY
CHAPA_ENCRYPTION_KEY=YOUR_PRODUCTION_ENCRYPTION_KEY
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_WEBHOOK_SECRET=GENERATE_STRONG_RANDOM_SECRET_FOR_WEBHOOK
CHAPA_TEST_MODE=false

# Payment Configuration - PRODUCTION
# CRITICAL: Update with your production domain (MUST use HTTPS)
PAYMENT_CALLBACK_URL=https://api.yourdomain.com/api/payments/webhook
PAYMENT_RETURN_URL=https://app.yourdomain.com/payment/return
PAYMENT_CURRENCY=ETB
PAYMENT_TIMEOUT=45000

# Email Configuration (for notifications)
# Use production email service (SendGrid, AWS SES, etc.)
EMAIL_HOST=smtp.youremailprovider.com
EMAIL_PORT=587
EMAIL_USER=your-production-email@yourdomain.com
EMAIL_PASS=YOUR_EMAIL_SERVICE_PASSWORD
EMAIL_FROM=noreply@yourdomain.com

# Frontend URLs - PRODUCTION
# CRITICAL: Update with your production domains (HTTPS required)
CUSTOMER_APP_URL=https://app.yourdomain.com
SELLER_APP_URL=https://seller.yourdomain.com
ADMIN_PANEL_URL=https://admin.yourdomain.com

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Security Settings
# Enable CORS only for your production domains
CORS_ORIGIN=https://app.yourdomain.com,https://seller.yourdomain.com,https://admin.yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/production.log

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# SSL/TLS Configuration
# Ensure SSL certificates are properly configured on your server
SSL_CERT_PATH=/path/to/ssl/certificate.crt
SSL_KEY_PATH=/path/to/ssl/private.key
